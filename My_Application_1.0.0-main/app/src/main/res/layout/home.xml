<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- 1. Header Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#09A459">
                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="85dp"
                    android:src="@drawable/logo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <LinearLayout
                    android:id="@+id/layoutAuthButtons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="@id/imgAvatar"
                    app:layout_constraintStart_toEndOf="@id/imgAvatar"
                    app:layout_constraintTop_toTopOf="@id/imgAvatar">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHomeLogin"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:backgroundTint="@color/white"
                        android:text="Đăng nhập"
                        android:textColor="@color/black"
                        android:textSize="10sp"
                        app:cornerRadius="18dp"
                        app:strokeColor="@color/white"
                        android:paddingHorizontal="12dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHomeRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/white"
                        android:text="ĐĂNG KÝ"
                        android:textColor="#D32F2F"
                        android:textSize="10sp"
                        app:cornerRadius="18dp"
                        android:paddingHorizontal="12dp" />
                </LinearLayout>
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Khách"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@id/imgAvatar"
                    app:layout_constraintStart_toEndOf="@id/imgAvatar"
                    app:layout_constraintTop_toTopOf="@id/imgAvatar" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 2. Search Bar -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-25dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center_vertical" android:paddingHorizontal="15dp">
                    <EditText android:id="@+id/etSearchHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@null" android:hint="Tìm kiếm" android:textSize="14sp" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_search" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. Sport Icons Grid (Added IDs for filtering) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:columnCount="4"
                android:paddingHorizontal="10dp">
                
                <LinearLayout android:id="@+id/btnPickleball" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:layout_marginBottom="15dp" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <androidx.cardview.widget.CardView android:layout_width="50dp" android:layout_height="50dp" app:cardCornerRadius="12dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/pickleball" /></androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pickleball" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnBadminton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <androidx.cardview.widget.CardView android:layout_width="50dp" android:layout_height="50dp" app:cardCornerRadius="12dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/badminton" /></androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cầu lông" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnFootball" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <androidx.cardview.widget.CardView android:layout_width="50dp" android:layout_height="50dp" app:cardCornerRadius="12dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/football" /></androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bóng đá" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnTennis" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <androidx.cardview.widget.CardView android:layout_width="50dp" android:layout_height="50dp" app:cardCornerRadius="12dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/tennis" /></androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tennis" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnVolleyball" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <androidx.cardview.widget.CardView android:layout_width="50dp" android:layout_height="50dp" app:cardCornerRadius="12dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/volleyball" /></androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B.Chuyền" android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btnBasketball" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                    <androidx.cardview.widget.CardView android:layout_width="50dp" android:layout_height="50dp" app:cardCornerRadius="12dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:src="@drawable/basketball" /></androidx.cardview.widget.CardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bóng rổ" android:textSize="11sp" />
                </LinearLayout>
            </GridLayout>

            <!-- 4. Dynamic List Section -->
            <TextView
                android:id="@+id/tvHomeListTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:text="Sân trống gợi ý cho bạn" 
                android:textColor="#333333" 
                android:textStyle="bold" 
                android:textSize="15sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
