<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F9F4">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarBooking"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#09A459"
        app:layout_constraintTop_toTopOf="parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp">
            <ImageView
                android:id="@+id/btnBackBooking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white" />
            <TextView
                android:id="@+id/tvVenueNameBooking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Đặt lịch"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Legend and Date Area -->
    <LinearLayout
        android:id="@+id/layoutHeaderInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#065F36"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarBooking">

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/custom_edittext"
            android:backgroundTint="#2E7D32"
            android:drawableEnd="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="15/04/2026"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="■ Trống" android:textColor="@color/white" android:textSize="10sp" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="■ Đã đặt" android:textColor="#E53935" android:textSize="10sp" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="■ Đang chọn" android:textColor="#FF9800" android:textSize="10sp" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="■ Khoá" android:textColor="#757575" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Lưu ý: Nếu bạn cần đặt lịch cố định vui lòng liên hệ admin để được hỗ trợ"
        android:textColor="#D32F2F"
        android:textSize="11sp"
        android:background="#FFEBEE"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderInfo"/>

    <!-- Booking Table Section -->
    <HorizontalScrollView
        android:id="@+id/hsvBookingTable"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/zoomSlider"
        app:layout_constraintTop_toBottomOf="@id/tvWarning">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBookingCourts"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:overScrollMode="never" />

        </LinearLayout>
    </HorizontalScrollView>

    <SeekBar
        android:id="@+id/zoomSlider"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:max="100"
        android:progress="0"
        app:layout_constraintBottom_toTopOf="@id/btnNext"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="16dp"
        android:backgroundTint="#FFB300"
        android:text="TIẾP THEO"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>