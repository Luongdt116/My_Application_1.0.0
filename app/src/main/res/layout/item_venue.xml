<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/imgField"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/badminton" />

            <!-- Nhãn Ưu đãi -->
            <TextView
                android:id="@+id/tvPromoBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bottom_sheet_background"
                android:backgroundTint="#D32F2F"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="ƯU ĐÃI"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFieldName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Tên sân bóng (Động)" />

                <!-- Thêm phần mô tả sân -->
                <TextView
                    android:id="@+id/tvFieldDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    tools:text="Mô tả ngắn về sân bóng, hệ thống đèn led chuẩn thi đấu..." />

                <TextView
                    android:id="@+id/tvPromoTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#D32F2F"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:visibility="gone"
                    tools:text="Giờ Vàng Sinh Viên - Giảm 30%"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvFieldLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    tools:text="Địa chỉ sân (Động)" />

                <TextView
                    android:id="@+id/tvFieldPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#D32F2F"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="Giá từ: 0đ (Động)" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBook"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/primary_green"
                android:paddingHorizontal="10dp"
                android:text="ĐẶT LỊCH"
                android:textSize="11sp"
                app:cornerRadius="18dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>